<Page
    x:Class="HaCompanionUWP.Views.ScriptsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HaCompanionUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <DataTemplate x:Key="ScriptCardTemplate">
            <Button Tag="{Binding EntityId}"
                    Click="EntityCard_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding FriendlyName}" Style="{StaticResource EntityLabelStyle}" />
                        <TextBlock Text="{Binding DisplayValue}" Style="{StaticResource EntityValueStyle}" />
                        <TextBlock Text="{Binding ContextLine}" Style="{StaticResource EntityContextStyle}" />
                    </StackPanel>
                </Border>
            </Button>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <ScrollViewer Padding="16,16,16,24">
            <StackPanel>
                <Border x:Name="ErrorCard" Visibility="Collapsed" Style="{StaticResource NudgeBorderStyle}">
                    <TextBlock x:Name="ErrorText" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap" />
                </Border>

                <TextBlock x:Name="EmptyText"
                           Text="Nenhum script encontrado."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Opacity="0.7"
                           Visibility="Collapsed"
                           Margin="0,0,0,12" />

                <ItemsControl x:Name="EntitiesList" ItemTemplate="{StaticResource ScriptCardTemplate}" />

                <Button x:Name="RefreshButton" Content="Atualizar" Click="Refresh_Click" HorizontalAlignment="Stretch" Margin="0,4,0,0" />
            </StackPanel>
        </ScrollViewer>

        <ProgressRing x:Name="LoadingRing" IsActive="False" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
