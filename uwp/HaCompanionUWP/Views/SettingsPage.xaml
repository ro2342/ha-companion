<Page
    x:Class="HaCompanionUWP.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HaCompanionUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="16,16,16,24">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Conexão com o Home Assistant" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="URL base" Style="{StaticResource EntityLabelStyle}" Margin="0,12,0,0" />
                    <TextBox x:Name="BaseUrlBox" PlaceholderText="http://192.168.x.x:8123" Margin="0,4,0,0" />

                    <TextBlock Text="Long-Lived Access Token" Style="{StaticResource EntityLabelStyle}" Margin="0,12,0,0" />
                    <PasswordBox x:Name="TokenBox" PlaceholderText="Gerado no seu perfil do Home Assistant" Margin="0,4,0,0" />

                    <TextBlock Text="Dashboard (url_path, opcional)" Style="{StaticResource EntityLabelStyle}" Margin="0,12,0,0" />
                    <TextBox x:Name="DashboardUrlPathBox" PlaceholderText="em branco = dashboard padrão da conta" Margin="0,4,0,0" />

                    <TextBlock x:Name="StatusText" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,12,0,0" Visibility="Collapsed" />

                    <Button x:Name="TestButton" Content="Testar conexão" Click="Test_Click" HorizontalAlignment="Stretch" Margin="0,12,0,0" />
                    <Button x:Name="SaveButton" Content="Salvar" Click="Save_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Favoritos" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Escolha quais entidades aparecem na tela inicial." Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <Button Content="Escolher favoritos" Click="ChooseFavorites_Click" HorizontalAlignment="Stretch" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Atualizações" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="CurrentVersionText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,4,0,0" />
                    <TextBlock x:Name="UpdateStatusText" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,8,0,0" Visibility="Collapsed" />
                    <ProgressBar x:Name="UpdateProgressBar" Minimum="0" Maximum="100" Visibility="Collapsed" Margin="0,8,0,0" />
                    <Button x:Name="CheckUpdateButton" Content="Verificar atualização" Click="CheckUpdate_Click" HorizontalAlignment="Stretch" Margin="0,12,0,0" />
                    <Button x:Name="InstallUpdateButton" Content="Instalar agora" Visibility="Collapsed" Click="InstallUpdate_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                    <Button x:Name="OpenDownloadPageButton" Content="Abrir página de download" Click="OpenDownloadPage_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource NudgeBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Limpar credenciais salvas neste aparelho." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" />
                    <Button Content="Sair / limpar" Click="ClearCredentials_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
