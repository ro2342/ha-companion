<Application
    x:Class="HaCompanionUWP.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <!--
          Estilos compartilhados entre as páginas, cores 100% do tema do
          sistema (claro/escuro + cor de destaque), sem paleta customizada —
          mesmo critério usado no ha-companion, ver ha-companion-w10m.md.
        -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="NudgeBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!-- Label pequeno em cinza (nome da entidade), valor grande em
             destaque (estado atual) e linha de contexto — as três partes
             do card de entidade descritas em ha-companion-w10m.md. -->
        <Style x:Key="EntityLabelStyle" TargetType="TextBlock">
            <Setter Property="Style" Value="{StaticResource CaptionTextBlockStyle}" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="EntityValueStyle" TargetType="TextBlock">
            <Setter Property="Style" Value="{StaticResource SubtitleTextBlockStyle}" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="EntityContextStyle" TargetType="TextBlock">
            <Setter Property="Style" Value="{StaticResource CaptionTextBlockStyle}" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="SectionDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,16,0,16" />
            <Setter Property="Background" Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
        </Style>

        <Style TargetType="PivotHeaderItem">
            <Setter Property="FontSize" Value="16" />
        </Style>
    </Application.Resources>

</Application>
